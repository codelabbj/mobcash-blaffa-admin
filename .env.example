# =============================================================================
# MobCash Blaffa Admin — configuration (.env.local en dev, Vercel en prod)
# Copier vers .env.local : cp .env.example .env.local
#
# Règle feature flags : variable absente, vide ou "true" → fonctionnalité activée.
# Mettre "false" pour masquer le menu et bloquer la route.
# =============================================================================

# --- API backend ---
# NEXT_PUBLIC_API_BASE_URL est prioritaire ; NEXT_PUBLIC_BASE_URL reste supporté (legacy).
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
# NEXT_PUBLIC_BASE_URL=https://api.example.com

# =============================================================================
# Fonctionnalités — toutes listées ici, true par défaut
# =============================================================================

# Tableau de bord (accueil / stats)
NEXT_PUBLIC_FEATURE_DASHBOARD=true

# Demandes de recharge
NEXT_PUBLIC_FEATURE_RECHARGES=true

# Demandes d'annulation
NEXT_PUBLIC_FEATURE_CANCELLATIONS=true

# Gestion des plateformes
NEXT_PUBLIC_FEATURE_PLATFORMS=true

# Gestion des caisses
NEXT_PUBLIC_FEATURE_CASHDESK=true

# Gestion des utilisateurs (wallet, permissions, commissions, transactions)
NEXT_PUBLIC_FEATURE_USERS=true

# Transactions administrateur
NEXT_PUBLIC_FEATURE_ADMIN_TRANSACTIONS=true

# Permissions globales
NEXT_PUBLIC_FEATURE_PERMISSIONS=true

# Configuration des commissions
NEXT_PUBLIC_FEATURE_COMMISSION_CONFIG=true

# Page profil (menu utilisateur)
NEXT_PUBLIC_FEATURE_PROFILE=true
